# --- Anthropic / Netlify AI Gateway ---
# When deployed on Netlify with AI Gateway enabled, ANTHROPIC_API_KEY and
# ANTHROPIC_BASE_URL are auto-injected. Set ANTHROPIC_API_KEY locally for `netlify dev`.
ANTHROPIC_API_KEY=

# --- Auth.js (Google OAuth) ---
# Generate AUTH_SECRET with: npx auth secret
AUTH_SECRET=
AUTH_URL=http://localhost:3000
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Trust the Auth.js URL behind Netlify's proxy.
AUTH_TRUST_HOST=true

# --- Database ---
# Netlify Database is provisioned via `netlify database init` and its connection
# is auto-discovered by @netlify/database. No connection string needed here.
# `netlify dev` spins up an embedded local Postgres; deploys run against the
# managed Netlify DB branch.
